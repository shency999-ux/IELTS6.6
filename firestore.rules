rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "shency999@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidMaterial(data) {
      return data.keys().hasAll(['title', 'type', 'createdAt', 'uid']) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 500 &&
             data.type in ['reading', 'writing', 'vocabulary', 'grammar'] &&
             data.createdAt is number &&
             data.uid is string;
    }

    match /materials/{materialId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.uid || isAdmin());
      allow create: if isAuthenticated() && isValidMaterial(request.resource.data) && request.resource.data.uid == request.auth.uid;
      allow update: if isAuthenticated() && isDocOwner() && isValidMaterial(request.resource.data) && request.resource.data.uid == resource.data.uid;
      allow delete: if isAuthenticated() && (isDocOwner() || isAdmin());
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId) || isAdmin();
    }
  }
}
